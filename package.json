{
  "name": "dishen-poetry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "start": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "sync": "ASTRO_TELEMETRY_DISABLED=1 astro sync",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "test": "vitest run",
    "test:pdf": "python3 -m unittest tests/pdf_import_test.py",
    "pdf:catalog": "python3 scripts/build_pdf_catalog.py --render",
    "pdf:publish": "python3 scripts/publish_pdf_catalog.py",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro check && vitest run && python3 -m unittest tests/pdf_import_test.py && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "5.3.0",
    "@fontsource-variable/noto-serif-sc": "5.3.0",
    "astro": "7.1.3",
    "opencc-js": "1.4.1"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "26.1.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
