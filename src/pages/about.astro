---
import Bilingual from '@/components/Bilingual.astro';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="关于谛深" description="关于谛深师父与本数字诗集。">
  <section class="about-page">
    <div class="shell about-page__grid">
      <div class="about-portrait" aria-label="师父照片待补充 / Portrait pending">
        <div class="about-portrait__mist" aria-hidden="true"></div>
        <span aria-hidden="true">谛</span>
        <p><Bilingual zh="师父照片 · 待补充" en="Portrait · To be added" /></p>
      </div>
      <article class="about-copy">
        <span class="eyebrow"><Bilingual zh="关于谛深" en="About Dishen" /></span>
        <h1><Bilingual zh="先读诗，再识人" en="The poems come first" /></h1>
        <div class="about-placeholder">
          <span class="about-placeholder__line"></span>
          <span class="about-placeholder__line"></span>
          <span class="about-placeholder__line about-placeholder__line--short"></span>
        </div>
        <p class="about-copy__status">
          <Bilingual
            zh="经确认的师父简介资料仍在整理中。此处保留内容位置，不以生成文字或 AI 肖像代替真实资料。"
            en="Verified biographical material is still being prepared. This space is reserved for real information and will not be filled with generated copy or an AI portrait."
          />
        </p>
        <a class="button-link" href="https://www.dishenbuddha.org/" target="_blank" rel="external noopener">
          <Bilingual zh="访问师父官方网站" en="Visit the official website" />
          <Icon name="external" />
        </a>
      </article>
    </div>
    <div class="shell about-project">
      <span class="eyebrow"><Bilingual zh="关于此数字诗集" en="About this collection" /></span>
      <p><Bilingual zh="这里以权威诗文为核心，通过克制的光、墨、留白与声音策展，提供可静观、可品读、可继续探索的公开空间。AI 只辅助私有制作，不公开解释诗中禅意。" en="This public collection centers the authoritative poems, using restrained light, ink, space, and—once approved—sound. AI may assist private production, but it does not publish interpretations of the poems." /></p>
    </div>
  </section>
</BaseLayout>
