---
import Bilingual from '@/components/Bilingual.astro';
import Icon from '@/components/Icon.astro';
import ScriptText from '@/components/ScriptText.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="关于谛深" description="谛深大师简介与官方资料。">
  <section class="about-page">
    <div class="shell about-page__inner">
      <figure class="about-banner" data-reveal>
        <img
          src="/images/shifu-banner.jpg"
          width="1920"
          height="650"
          alt="谛深大师身着黄色僧袍的横幅照片"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </figure>
      <div class="about-page__content">
        <article class="about-copy">
          <span class="eyebrow"><Bilingual zh="关于谛深" en="About Dishen" /></span>
          <h1><Bilingual zh="谛深大师" en="Master Dishen" /></h1>
          <p class="about-copy__intro">
            <ScriptText text="谛深大师俗姓吕，净土获证，禅宗传承。上乘清净愿力为谛，下令众生世界业障破灭称深。谛深法号为佛光普照神僧呼唤所得。落发戒名释迦妙生，祖籍山东即墨。" />
          </p>
          <a
            class="button-link"
            href="https://www.dishenbuddha.org/%E8%B0%9B%E6%B7%B1%E5%A4%A7%E5%B8%88%E7%AE%80%E4%BB%8B"
            target="_blank"
            rel="external noopener"
          >
            <Bilingual zh="查看完整简介" en="View the full biography" />
            <Icon name="external" />
          </a>
        </article>
        <blockquote class="about-verse">
          <span class="eyebrow"><Bilingual zh="偈" en="Verse" /></span>
          <p><ScriptText text="独行僧　坐十方界外　钵盛众生诸大苦海　化无尽甘露" /></p>
          <p><ScriptText text="清净尊　立小土尘中　盂布如来许丝香云　成有生宝刹" /></p>
        </blockquote>
      </div>
    </div>
    <div class="shell about-project">
      <span class="eyebrow"><Bilingual zh="关于此数字诗集" en="About this collection" /></span>
      <p><Bilingual zh="本网站收录谛深大师诗作，并按创作日期呈现。" en="This collection presents Master Dishen's poems by the dates they were written." /></p>
    </div>
  </section>
</BaseLayout>
