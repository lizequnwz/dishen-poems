---
import Bilingual from '@/components/Bilingual.astro';
import Icon from '@/components/Icon.astro';
import PoemPanel from '@/components/PoemPanel.astro';
import ScriptText from '@/components/ScriptText.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getResolvedVisualSequence, loadSiteData, poemPath } from '@/lib/site-data';

const { latestPoems, publicPoems, years } = await loadSiteData();
const randomPaths = JSON.stringify(publicPoems.map(poemPath));
const latestVisualProfiles = getResolvedVisualSequence(latestPoems);
const oldestYear = years.at(-1);
---

<BaseLayout>
  <section class="home-hero">
    <div class="home-hero__landscape" aria-hidden="true">
      <div class="home-hero__moon"></div>
      <svg viewBox="0 0 1200 680" preserveAspectRatio="xMidYMid slice">
        <path d="M-40 590 Q170 380 340 525 T680 460 T1240 555"></path>
        <path d="M-40 640 Q200 465 370 585 T720 535 T1240 615"></path>
      </svg>
      <span class="home-hero__mist home-hero__mist--one"></span>
      <span class="home-hero__mist home-hero__mist--two"></span>
    </div>
    <div class="shell home-hero__inner">
      <div class="home-hero__intro" data-reveal>
        <span class="eyebrow"><Bilingual zh="谛深禅诗 · 近日诗卷" en="Dishen Zen Poetry · Latest Five" /></span>
        <h1>
          <span><Bilingual zh="静候" en="A scroll" /></span>
          <span><Bilingual zh="一卷" en="of mountain" /></span>
          <span><Bilingual zh="山水" en="and mist" /></span>
        </h1>
        <p>
          <Bilingual
            zh="每逢新作入藏，这里便呈上创作日期最近的五首。"
            en="Whenever a new poem enters the archive, this scroll renews itself with the latest five."
          />
        </p>
        <div class="home-hero__actions">
          <a class="button-link" href="#poem-1">
            <Bilingual zh="入卷" en="Enter the scroll" />
            <Icon name="arrow" />
          </a>
        </div>
      </div>
      <div class="home-hero__seal" aria-hidden="true">
        <span><ScriptText text="诗" /></span><span><ScriptText text="境" /></span>
        <small>新</small>
      </div>
    </div>
    <a class="scroll-cue" href="#poem-1">
      <span><Bilingual zh="向下入境" en="Scroll to enter" /></span>
      <i aria-hidden="true"></i>
    </a>
  </section>

  <section class="exhibition-intro shell">
    <div>
      <span class="eyebrow"><Bilingual zh="按创作日期" en="By written date" /></span>
      <h2><Bilingual zh="近日诗卷" en="Latest Five" /></h2>
    </div>
    <p><Bilingual zh="由新至旧 · 自动更新" en="Newest first · Always current" /></p>
  </section>

  <div class="poem-scroll">
    {latestPoems.map((poem, index) => (
      <PoemPanel poem={poem} index={index} total={latestPoems.length} visualProfile={latestVisualProfiles[index]} />
    ))}
  </div>

  <section class="year-ring shell" aria-labelledby="year-ring-title">
    <div class="year-ring__orbit" aria-hidden="true"><i></i><span>{publicPoems.length}</span></div>
    <div class="year-ring__copy">
      <span class="eyebrow"><Bilingual zh="诗卷年轮" en="Archive rings" /></span>
      <h2 id="year-ring-title"><Bilingual zh={`${oldestYear} 至 ${years[0]}`} en={`${oldestYear} to ${years[0]}`} /></h2>
      <p><Bilingual zh={`共 ${publicPoems.length} 首诗，循 ${years.length} 个创作年份展开。`} en={`${publicPoems.length} poems across ${years.length} years of writing.`} /></p>
    </div>
    <a class="text-link" href="/archive/"><Bilingual zh="浏览年份画廊" en="Browse the year gallery" /><Icon name="arrow" /></a>
  </section>

  <section class="journey-end">
    <div class="shell journey-end__inner">
      <div class="journey-end__heading">
        <span class="eyebrow"><Bilingual zh="卷尾 · 亦是入口" en="The end is another beginning" /></span>
        <h2><Bilingual zh="再游一境" en="Where will you wander next?" /></h2>
      </div>
      <div class="journey-options">
        <button class="journey-card" type="button" data-random-paths={randomPaths}>
          <span class="journey-card__index">01</span>
          <Icon name="random" size={24} />
          <strong><Bilingual zh="随机漫游" en="Wander at random" /></strong>
          <p><Bilingual zh="由一首诗，走向另一场风、雨、雪或花。" en="Let one poem lead you to another season." /></p>
        </button>
        <a class="journey-card" href="/archive/">
          <span class="journey-card__index">02</span>
          <Icon name="archive" size={24} />
          <strong><Bilingual zh="进入时间档案" en="Enter the archive" /></strong>
          <p><Bilingual zh="依创作日期查看所有诗作。" en="Browse every poem by written date." /></p>
        </a>
        <a class="journey-card" href="/about/">
          <span class="journey-card__index">03</span>
          <span class="journey-card__monogram" aria-hidden="true"><ScriptText text="谛" /></span>
          <strong><Bilingual zh="关于谛深" en="Meet Dishen" /></strong>
          <p><Bilingual zh="了解谛深大师生平与法号由来。" en="Learn about Master Dishen's life and Dharma name." /></p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
