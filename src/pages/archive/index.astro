---
import Bilingual from '@/components/Bilingual.astro';
import Icon from '@/components/Icon.astro';
import InkScene from '@/components/InkScene.astro';
import ScriptText from '@/components/ScriptText.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatWrittenDate, loadSiteData, poemPath } from '@/lib/site-data';
import { resolveYearVisualProfile } from '@/lib/visual-profile';

const { publicPoems, years } = await loadSiteData();
const randomPaths = JSON.stringify(publicPoems.map(poemPath));
const yearGroups = years.map((year, index) => {
  const poems = publicPoems.filter((poem) => poem.data.writtenDate.startsWith(year));
  return {
    year,
    index,
    poems,
    newest: poems[0],
    oldest: poems.at(-1)!,
    profile: resolveYearVisualProfile(year),
  };
});
---

<BaseLayout title="作品档案" description="按谛深大师创作年份浏览诗作。">
  <header class="page-hero archive-hero archive-hero--gallery">
    <div class="shell page-hero__inner">
      <div>
        <span class="eyebrow"><Bilingual zh="作品档案 · 年份画廊" en="Poetry archive · Year gallery" /></span>
        <h1><Bilingual zh="循时间，见诗境" en="Poems across time" /></h1>
        <p><Bilingual zh="每一年是一方庭院，循创作日期由近及远。" en="Each year opens as its own courtyard, newest to oldest." /></p>
      </div>
      <div class="archive-hero__count">
        <strong>{String(publicPoems.length).padStart(2, '0')}</strong>
        <span><Bilingual zh={`首诗作 · ${years.length} 个年份`} en={`poems · ${years.length} years`} /></span>
      </div>
    </div>
  </header>

  <div class="archive-toolbar shell">
    <nav aria-label="按年份浏览 / Browse by year">
      <a aria-current="page" href="/archive/"><Bilingual zh="年份画廊" en="Years" /></a>
      {years.map((year) => <a href={`/archive/${year}/`}>{year}</a>)}
    </nav>
    <button class="outline-button" type="button" data-random-paths={randomPaths}>
      <Icon name="random" /><Bilingual zh="随机漫游" en="Random poem" />
    </button>
  </div>

  <section class="year-gallery shell" aria-label="诗歌年份 / Poetry years">
    {yearGroups.map((group) => (
      <a class:list={['year-card', `year-card--${group.profile.sceneFamily}`]} href={`/archive/${group.year}/`} data-reveal>
        <InkScene profile={group.profile} title={group.year} index={group.index} />
        <span class="year-card__index">{String(group.index + 1).padStart(2, '0')}</span>
        <div class="year-card__heading">
          <strong>{group.year}</strong>
          <span>{group.poems.length} <Bilingual zh="首" en="poems" /></span>
        </div>
        <div class="year-card__meta">
          <span>{formatWrittenDate(group.oldest.data.writtenDate)} — {formatWrittenDate(group.newest.data.writtenDate)}</span>
          <h2><ScriptText text={group.newest.data.title} originalScript={group.newest.data.originalScript} /></h2>
          <p><Bilingual zh="从这一年入卷" en="Enter this year's scroll" /> <Icon name="arrow" /></p>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
