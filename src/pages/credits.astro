---
import Bilingual from '@/components/Bilingual.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { approvedAudioAssets } from '@/lib/audio-data';
---

<BaseLayout title="素材与署名" description="谛深禅诗网站所用图片、字体与开源软件的来源和许可信息。">
  <header class="page-hero credits-hero">
    <div class="shell page-hero__inner">
      <div>
        <span class="eyebrow"><Bilingual zh="来源与许可" en="Sources & licenses" /></span>
        <h1><Bilingual zh="素材与署名" en="Media & credits" /></h1>
        <p><Bilingual zh="本网站当前使用的图片、字体与开源软件。" en="Images, typefaces, and open-source software used by this website." /></p>
      </div>
    </div>
  </header>

  <section class="credits-content shell">
    <div class="credits-grid">
      <article>
        <span>01</span>
        <h3><Bilingual zh="正式照片" en="Official photograph" /></h3>
        <p>
          <Bilingual zh="谛深大师横幅照片 · 官方资料。" en="Master Dishen banner photograph · Official material." />
          {' '}<a href="https://www.dishenbuddha.org/" target="_blank" rel="external noopener"><Bilingual zh="来源网站" en="Source website" /></a>
        </p>
      </article>
      <article>
        <span>02</span>
        <h3><Bilingual zh="字体" en="Typefaces" /></h3>
        <p>Noto Serif SC / Noto Sans SC · SIL Open Font License.</p>
      </article>
      <article>
        <span>03</span>
        <h3><Bilingual zh="开源软件" en="Open-source software" /></h3>
        <p>Astro · MIT License.<br />OpenCC / opencc-js · Apache-2.0 / MIT.</p>
      </article>
      {approvedAudioAssets.map((asset, index) => (
        <article>
          <span>{String(index + 4).padStart(2, '0')}</span>
          <h3><Bilingual zh={asset.title.zh} en={asset.title.en} /></h3>
          <p>
            {asset.creator} · <a href={asset.sourcePage} target="_blank" rel="external noopener">{asset.originalFile}</a><br />
            <a href={asset.license.url} target="_blank" rel="license noopener">{asset.license.name}</a> · {asset.retrievedAt}<br />
            MP3 SHA-256: <code>{asset.mp3.sha256}</code>
          </p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
