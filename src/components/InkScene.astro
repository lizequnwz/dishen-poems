---
import type { ResolvedVisualProfile, VisualMotif, VisualPalette } from '@/lib/visual-profile';

interface Props {
  profile: ResolvedVisualProfile;
  title: string;
  index?: number;
}

const { profile, title, index = 0 } = Astro.props;
const palettes: Record<VisualPalette, { accent: string; glow: string; ink: string }> = {
  spring: { accent: '#a96f72', glow: '#d9bc8d', ink: '#55736a' },
  jade: { accent: '#7d9b62', glow: '#d7bd6d', ink: '#47645a' },
  rain: { accent: '#b27777', glow: '#dba95b', ink: '#426875' },
  storm: { accent: '#8a647d', glow: '#d19b55', ink: '#526a73' },
  winter: { accent: '#a0574d', glow: '#c7d1cc', ink: '#4c5d5d' },
  moonlit: { accent: '#8798a5', glow: '#d8d3bb', ink: '#334f59' },
  paper: { accent: '#a46a55', glow: '#d8bf8e', ink: '#60635b' },
};
const palette = palettes[profile.palette];
const has = (motif: VisualMotif) => profile.motifs.includes(motif);
const filterId = `mist-${profile.palette}-${profile.composition}-${index}`;
---

<div
  class:list={[
    'ink-scene',
    `ink-scene--${profile.composition}`,
    `ink-scene--${profile.light}`,
    `ink-scene--${profile.intensity}`,
  ]}
  style={`--scene-accent:${palette.accent};--scene-glow:${palette.glow};--scene-ink:${palette.ink};`}
  data-composition={profile.composition}
  aria-hidden="true"
>
  {(has('sun') || profile.light === 'dawn' || profile.light === 'day') && <div class="ink-scene__celestial ink-scene__celestial--sun"></div>}
  {(has('moon') || profile.light === 'night') && <div class="ink-scene__celestial ink-scene__celestial--moon"></div>}
  <div class="ink-scene__wash ink-scene__wash--one"></div>
  <div class="ink-scene__wash ink-scene__wash--two"></div>
  <svg class="ink-scene__drawing" viewBox="0 0 1000 720" preserveAspectRatio="xMidYMid slice">
    <defs>
      <filter id={filterId} x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="2.2"></feGaussianBlur>
      </filter>
    </defs>
    <g class="scene-composition">
      {has('mountain') && (
        <g class="scene-mountain">
          <path class="scene-line scene-line--soft" d="M-60 590 165 315 300 510 472 205 650 500 805 330 1060 590"></path>
          <path class="scene-line" d="M-40 632 180 370 320 555 485 275 655 548 820 390 1040 625"></path>
        </g>
      )}
      {has('water') && (
        <g class="scene-water">
          <path d="M-20 540 Q180 490 370 545 T760 530 T1040 550"></path>
          <path d="M80 600 Q245 555 410 602 T760 590 T970 610"></path>
        </g>
      )}
      {has('mist') && (
        <g class="scene-mist" filter={`url(#${filterId})`}>
          <path d="M-40 455 Q180 395 390 448 T820 430 T1050 462"></path>
          <path d="M120 510 Q320 470 520 512 T920 496"></path>
        </g>
      )}
      {has('rain') && (
        <g class="scene-rain">
          <path d="M120 120l-72 142M235 88l-82 164M365 125l-76 150M505 75l-98 190M650 110l-86 168M795 70l-102 194M930 118l-70 140"></path>
        </g>
      )}
      {has('snow') && (
        <g class="scene-snow">
          <circle cx="110" cy="150" r="5"></circle><circle cx="215" cy="225" r="3"></circle>
          <circle cx="335" cy="112" r="4"></circle><circle cx="455" cy="202" r="6"></circle>
          <circle cx="575" cy="128" r="3"></circle><circle cx="705" cy="175" r="5"></circle>
          <circle cx="820" cy="96" r="4"></circle><circle cx="910" cy="235" r="3"></circle>
        </g>
      )}
      {has('flora') && (
        <g class="scene-flora">
          <path class="scene-branch" d="M760 720c-7-205 62-278 24-446m5 120 90-105m-102 184-126-96"></path>
          <g class="scene-petals">
            <circle cx="875" cy="286" r="7"></circle><circle cx="835" cy="330" r="4"></circle>
            <circle cx="650" cy="377" r="8"></circle><circle cx="735" cy="418" r="5"></circle>
          </g>
        </g>
      )}
      {has('wind') && (
        <g class="scene-wind">
          <path d="M110 320 Q310 255 485 320 T860 300"></path>
          <path d="M240 382 Q420 340 575 390 T910 370"></path>
        </g>
      )}
      {has('brush') && (
        <g class="scene-brushwork">
          <path class="scene-brush" d="M40 635 C250 510 390 430 555 295 C690 185 800 160 980 82"></path>
          <path class="scene-brush scene-brush--echo" d="M125 685 C330 590 455 500 620 395 C750 312 850 285 960 245"></path>
        </g>
      )}
      {has('lightning') && <path class="scene-lightning" d="m430 78-88 168h92L312 455"></path>}
    </g>
  </svg>
  <span class="ink-scene__title">{title}</span>
</div>
