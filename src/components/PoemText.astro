---
import type { PoemEntry } from '@/lib/site-data';
import { getPoemVariants } from '@/lib/site-data';
import { poemLineTier, poemSourceLines, type PoemLineTier } from '@/lib/poem-layout';

interface Props {
  poem: PoemEntry;
  tier?: PoemLineTier;
}

const { poem, tier = poemLineTier(poem.body ?? '') } = Astro.props;
const variants = getPoemVariants(poem);
---

<div
  class:list={['poem-text', `poem-text--${tier}`]}
  data-poem-scroll-region
  data-line-tier={tier}
  aria-label="诗文原行 / Poem lines"
>
  {(['simplified', 'traditional'] as const).map((mode) => (
    <div data-script-copy={mode} lang={mode === 'traditional' ? 'zh-Hant' : 'zh-Hans'}>
      {poemSourceLines(variants[mode]).map((line) => <span class="poem-text__line">{line || '\u00A0'}</span>)}
    </div>
  ))}
</div>
