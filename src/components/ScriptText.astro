---
import { deriveTextVariants, type OriginalScript, type ScriptOverrides } from '@/lib/script-conversion';

interface Props {
  text: string;
  originalScript?: OriginalScript;
  overrides?: ScriptOverrides;
}

const {
  text,
  originalScript = 'simplified',
  overrides = { simplified: {}, traditional: {} },
} = Astro.props;
const variants = deriveTextVariants(text, originalScript, overrides);
---

<span data-script-inline="simplified" lang="zh-Hans">{variants.simplified}</span>
<span data-script-inline="traditional" lang="zh-Hant">{variants.traditional}</span>
